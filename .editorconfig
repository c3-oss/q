root = true

[*]
end_of_line              = lf
insert_final_newline     = true
charset                  = utf-8
trim_trailing_whitespace = true
indent_style             = space

[*.go]
indent_style = tab

[*.{yml,yaml,json,jsonc,html,css,js,cjs,mjs,ts,tsx,toml}]
indent_size = 2

[*.md]
indent_size = 2

[*.sh]
indent_size = 4

[Makefile]
indent_style = tab

[.justfile]
indent_size = 2
