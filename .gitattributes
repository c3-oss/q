# Auto-detect text files and normalize line endings to LF in the repo.
* text=auto eol=lf

# Explicitly mark generated assets as binary so diffs stay readable.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary

# Exclude from language stats / archives.
docs/**    linguist-documentation
testdata/** linguist-vendored
